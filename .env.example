# Copy to .env and fill in real values. Never commit the real .env.

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# Database
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
PORT=3001

# AWS S3
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS: comma-separated list of allowed origins. Use * only for local dev.
CORS_ORIGINS=
